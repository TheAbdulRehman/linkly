# ── .env.example ───────────────────────────────────────────────
# This file is a TEMPLATE. It is committed to git so teammates know
# WHICH variables the app needs — but it holds NO real secrets.
# Copy it to a real `.env` (which is gitignored) and fill in values.
#   cp .env.example .env

# The port your server listens on. Code reads this via process.env.PORT.
PORT=8000

# Your Neon Postgres connection string.
# Get it from: Neon Console -> your project -> "Connection Details".
# Use the POOLED connection string (host contains "-pooler") for app queries.
# Format below is a placeholder — do NOT put a real password here.
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require
